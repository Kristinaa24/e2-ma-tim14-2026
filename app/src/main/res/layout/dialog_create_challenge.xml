<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/challenge_dialog_hint"
        android:textColor="@color/slagalica_dark_blue"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/challengeTokensInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/challenge_tokens_hint"
        android:inputType="number"
        android:maxLines="1" />

    <EditText
        android:id="@+id/challengeStarsInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:hint="@string/challenge_stars_hint"
        android:inputType="number"
        android:maxLines="1" />
</LinearLayout>
