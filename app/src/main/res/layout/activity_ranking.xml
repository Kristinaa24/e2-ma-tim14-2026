<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/rankingBackButton"
            android:layout_width="44dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_home_shortcut_tile"
            android:gravity="center"
            android:text="&lt;"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/tab_rankings"
            android:textColor="@color/slagalica_yellow"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_lobby_tab_strip"
        android:orientation="horizontal"
        android:padding="6dp">

        <TextView
            android:id="@+id/weeklyTabButton"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/bg_lobby_tab_active"
            android:gravity="center"
            android:text="@string/weekly_ranking_title"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/monthlyTabButton"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_lobby_tab_inactive"
            android:gravity="center"
            android:text="@string/monthly_ranking_title"
            android:textColor="@color/slagalica_dark_blue"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_home_panel"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/rankingTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/slagalica_yellow"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/rankingCycleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/slagalica_light_blue"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_home_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="9dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="@string/ranking_header_position"
                android:textColor="@color/slagalica_dark_blue"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/ranking_header_player"
                android:textColor="@color/slagalica_dark_blue"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ranking_header_stars"
                android:textColor="@color/slagalica_dark_blue"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ListView
            android:id="@+id/rankingListView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"
            android:focusable="false"
            android:listSelector="@android:color/transparent" />
    </LinearLayout>
</LinearLayout>