<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_round_title_bar"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:text="@string/asocijacije"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_round_board"
            android:orientation="vertical"
            android:padding="2dp">

            <!-- Top Row: A and B -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- Column A -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="1dp">
                    <Button android:id="@+id/btnA1" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_a1" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnA2" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_a2" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnA3" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_a3" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnA4" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_a4" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <EditText android:id="@+id/etSolutionA" style="@style/SlagalicaQuestionField" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.2" android:hint="@string/column_a" android:textSize="13sp" android:padding="2dp" android:inputType="textCapCharacters" android:gravity="center" android:background="@drawable/bg_button_primary" android:autofillHints="none" android:minHeight="0dp"/>
                </LinearLayout>

                <!-- Column B -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="1dp">
                    <Button android:id="@+id/btnB1" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_b1" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnB2" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_b2" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnB3" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_b3" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnB4" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_b4" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <EditText android:id="@+id/etSolutionB" style="@style/SlagalicaQuestionField" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.2" android:hint="@string/column_b" android:textSize="13sp" android:padding="2dp" android:inputType="textCapCharacters" android:gravity="center" android:background="@drawable/bg_button_primary" android:autofillHints="none" android:minHeight="0dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Final Solution -->
            <EditText
                android:id="@+id/etFinalSolution"
                style="@style/SlagalicaQuestionField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="4dp"
                android:background="@color/slagalica_red"
                android:hint="@string/final_solution"
                android:textColor="@color/white"
                android:textColorHint="@color/white"
                android:textSize="16sp"
                android:gravity="center"
                android:inputType="textCapCharacters"
                android:autofillHints="none"
                android:minHeight="44dp" />

            <!-- Bottom Row: C and D -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- Column C -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="1dp">
                    <EditText android:id="@+id/etSolutionC" style="@style/SlagalicaQuestionField" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.2" android:hint="@string/column_c" android:textSize="13sp" android:padding="2dp" android:inputType="textCapCharacters" android:gravity="center" android:background="@drawable/bg_button_primary" android:layout_marginBottom="1dp" android:autofillHints="none" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnC1" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_c1" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnC2" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_c2" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnC3" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_c3" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnC4" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_c4" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                </LinearLayout>

                <!-- Column D -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="1dp">
                    <EditText android:id="@+id/etSolutionD" style="@style/SlagalicaQuestionField" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.2" android:hint="@string/column_d" android:textSize="13sp" android:padding="2dp" android:inputType="textCapCharacters" android:gravity="center" android:background="@drawable/bg_button_primary" android:layout_marginBottom="1dp" android:autofillHints="none" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnD1" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_d1" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnD2" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_d2" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnD3" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_d3" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                    <Button android:id="@+id/btnD4" style="@style/SlagalicaSecondaryButton" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="@string/label_d4" android:layout_marginBottom="1dp" android:padding="0dp" android:textSize="11sp" android:minHeight="0dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/confirmSolutionButton"
            style="@style/SlagalicaConfirmButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:text="@string/confirm" />

    </LinearLayout>
</ScrollView>
