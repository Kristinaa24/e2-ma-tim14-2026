<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slagalica_blue"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <include layout="@layout/player_status_bar" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="@dimen/space_small">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="P1: 0"
            android:textColor="@color/white"
            android:textSize="@dimen/subtitle_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/avatar_silver"
            android:padding="6dp"
            android:text="30s"
            android:textColor="@color/slagalica_dark_blue"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="P2: 0"
            android:textColor="@color/white"
            android:textSize="@dimen/subtitle_text_size"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        style="@style/SlagalicaTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/skocko"
        android:layout_marginBottom="@dimen/space_medium" />

    <!-- Game Board (6 attempts) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:orientation="horizontal">

            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" android:gravity="center" android:textSize="24sp" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" android:gravity="center" android:textSize="24sp" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" android:gravity="center" android:textSize="24sp" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" android:gravity="center" android:textSize="24sp" />

            <!-- Indicators -->
            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:columnCount="2"
                android:rowCount="2">
                <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" />
                <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" />
                <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" />
                <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" />
            </GridLayout>
        </LinearLayout>

        <!-- Repeat for other rows with slightly updated dimensions for visibility -->
        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="4dp" android:orientation="horizontal">
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <GridLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:columnCount="2"><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /></GridLayout>
        </LinearLayout>
        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="4dp" android:orientation="horizontal">
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <GridLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:columnCount="2"><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /></GridLayout>
        </LinearLayout>
        <!-- Row 4 -->
        <LinearLayout
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="4dp" android:orientation="horizontal">
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <GridLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:columnCount="2"><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /></GridLayout>
        </LinearLayout>
        <!-- Row 5 -->
        <LinearLayout
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="4dp" android:orientation="horizontal">
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <GridLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:columnCount="2"><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /></GridLayout>
        </LinearLayout>
        <!-- Row 6 -->
        <LinearLayout
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="4dp" android:orientation="horizontal">
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <TextView android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:background="@color/slagalica_light_blue" />
            <GridLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:columnCount="2"><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /><View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="2dp" android:background="@color/light_gray" /></GridLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Symbol Selection Palette -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button style="@style/SlagalicaAnswerButton" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="2dp" android:text="@string/skocko_symbol" android:padding="0dp" android:textSize="20sp"/>
        <Button style="@style/SlagalicaAnswerButton" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="2dp" android:text="@string/square_symbol" android:padding="0dp" android:textSize="20sp"/>
        <Button style="@style/SlagalicaAnswerButton" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="2dp" android:text="@string/circle_symbol" android:padding="0dp" android:textSize="20sp"/>
        <Button style="@style/SlagalicaAnswerButton" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="2dp" android:text="@string/heart_symbol" android:padding="0dp" android:textSize="20sp"/>
        <Button style="@style/SlagalicaAnswerButton" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="2dp" android:text="@string/triangle_symbol" android:padding="0dp" android:textSize="20sp"/>
        <Button style="@style/SlagalicaAnswerButton" android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="2dp" android:text="@string/star_symbol" android:padding="0dp" android:textSize="20sp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnSubmitSkocko"
        style="@style/SlagalicaConfirmButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_medium"
        android:text="@string/submit_combination" />

    <Button
        android:id="@+id/btnQuitSkocko"
        style="@style/SlagalicaDangerButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_small"
        android:layout_marginHorizontal="@dimen/space_medium"
        android:text="@string/quit_game" />

</LinearLayout>