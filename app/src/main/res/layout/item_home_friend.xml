<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_home_shortcut_tile"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/friendRegularContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/friendRankText"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/slagalica_light_blue"
            android:textSize="14sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp">

            <ImageView
                android:id="@+id/friendAvatarImage"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_avatar_circle"
                android:contentDescription="@string/player_avatar"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:id="@+id/friendInitialText"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_avatar_circle"
                android:gravity="center"
                android:textColor="@color/slagalica_dark_blue"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/friendNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/friendStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/slagalica_light_blue"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/friendMonthlyRankText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/slagalica_light_blue"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/friendLeagueText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/slagalica_yellow"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_stars_icon"
                android:textColor="@color/slagalica_yellow"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/friendStarsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/slagalica_light_blue"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/friendInviteButton"
            style="@style/SlagalicaConfirmButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="72dp"
            android:text="@string/friend_invite_action" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/friendInviteContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_avatar_circle"
            android:gravity="center"
            android:text="@string/friend_invite_initial"
            android:textColor="@color/slagalica_dark_blue"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/friend_invite_title"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="@string/friend_invite_subtitle_home"
            android:textColor="@color/slagalica_light_blue"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
