<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical">

    <TextView
        android:id="@+id/placeholderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_round_title_bar"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp"
        android:text="@string/placeholder_round_title"
        android:textColor="@color/white"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/placeholderText"
        style="@style/SlagalicaInfoCardBlue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/placeholder_round_message" />

    <Button
        android:id="@+id/btnContinueRound"
        style="@style/SlagalicaConfirmButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:text="@string/continue_match" />
</LinearLayout>
