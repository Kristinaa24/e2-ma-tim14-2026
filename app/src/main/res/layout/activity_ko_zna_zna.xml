<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="@dimen/screen_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <include layout="@layout/player_status_bar" />

        <TextView
            style="@style/SlagalicaTitle"
            android:text="@string/ko_zna_zna"
            android:layout_marginTop="@dimen/space_small"
            android:background="@color/slagalica_dark_blue"
            android:padding="@dimen/card_padding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            style="@style/SlagalicaCard"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/space_medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/gameTimerText"
                android:text="@string/time_25"
                android:textSize="@dimen/body_text_size"
                android:textStyle="bold"
                android:textColor="@color/slagalica_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/questionTimerText"
                android:text="@string/question_time_5"
                android:textSize="@dimen/body_text_size"
                android:textColor="@color/slagalica_text"
                android:layout_marginTop="@dimen/space_small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/questionCounterText"
                android:text="@string/question_counter"
                android:textSize="@dimen/body_text_size"
                android:textStyle="bold"
                android:textColor="@color/slagalica_text"
                android:layout_marginTop="@dimen/space_small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/space_medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/playerOneScoreText"
                style="@style/SlagalicaCard"
                android:text="@string/player_one_score"
                android:textStyle="bold"
                android:textColor="@color/slagalica_text"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/playerTwoScoreText"
                style="@style/SlagalicaCard"
                android:text="@string/player_two_score"
                android:textStyle="bold"
                android:textColor="@color/slagalica_text"
                android:gravity="center"
                android:layout_marginStart="@dimen/space_medium"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:id="@+id/ruleInfoText"
            style="@style/SlagalicaInfoCardBlue"
            android:textSize="@dimen/small_text_size"
            android:layout_marginTop="@dimen/space_medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/questionText"
            style="@style/SlagalicaQuestionField"
            android:text="@string/question_placeholder"
            android:textSize="@dimen/subtitle_text_size"
            android:layout_marginTop="@dimen/space_large"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/answerAButton"
            style="@style/SlagalicaAnswerButton"
            android:text="@string/answer_a"
            android:layout_marginTop="@dimen/space_medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/answerBButton"
            style="@style/SlagalicaAnswerButton"
            android:text="@string/answer_b"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/answerCButton"
            style="@style/SlagalicaAnswerButton"
            android:text="@string/answer_c"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/answerDButton"
            style="@style/SlagalicaAnswerButton"
            android:text="@string/answer_d"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/playerTwoAnswerButton"
            style="@style/SlagalicaSecondaryButton"
            android:text="@string/player_two_answer"
            android:layout_marginTop="@dimen/space_medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/koZnaZnaQuitButton"
            style="@style/SlagalicaDangerButton"
            android:text="@string/quit_game"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

</ScrollView>