<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCF6FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/spojnice"
            android:textColor="#3D3944"
            android:textSize="30sp"
            android:textStyle="bold" />

        <LinearLayout
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:padding="14dp"
            android:layout_marginTop="14dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/roundText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/round_one"
                android:textColor="#3D3944"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/currentPlayerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/current_player_one"
                android:textColor="#3D3944"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/timerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_30"
                android:textColor="#3D3944"
                android:textSize="17sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/playerOneScoreText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#FFFFFF"
                android:elevation="3dp"
                android:padding="12dp"
                android:text="@string/player_one_zero"
                android:textColor="#3D3944"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/playerTwoScoreText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="#FFFFFF"
                android:elevation="3dp"
                android:padding="12dp"
                android:text="@string/player_two_zero"
                android:textColor="#3D3944"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/ruleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:padding="14dp"
            android:text="@string/spojnice_rules"
            android:textColor="#3D3944"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/secondChanceInfoText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:padding="12dp"
            android:text="@string/second_chance_message"
            android:textColor="#3D3944"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <Button
                    android:id="@+id/left1Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adele" />

                <Button
                    android:id="@+id/left2Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/lady_gaga" />

                <Button
                    android:id="@+id/left3Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ariana_grande" />

                <Button
                    android:id="@+id/left4Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/taylor_swift" />

                <Button
                    android:id="@+id/left5Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/beyonce" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <Button
                    android:id="@+id/right1Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/halo" />

                <Button
                    android:id="@+id/right2Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/hello" />

                <Button
                    android:id="@+id/right3Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/shake_it_off" />

                <Button
                    android:id="@+id/right4Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/bad_romance" />

                <Button
                    android:id="@+id/right5Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/seven_rings" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/selectedPairText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:padding="12dp"
            android:text="@string/selected_pair_none"
            android:textColor="#3D3944" />

        <Button
            android:id="@+id/confirmConnectionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/confirm_connection" />

        <Button
            android:id="@+id/spojniceQuitButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF6B6B"
            android:text="@string/quit_game"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</ScrollView>