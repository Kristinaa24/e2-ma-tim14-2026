<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slagalica_blue"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">
        <include layout="@layout/player_status_bar" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/slagalica_dark_blue"
            android:gravity="center"
            android:padding="14dp"
            android:text="@string/spojnice"
            android:layout_marginTop="10dp"
            android:textColor="@color/slagalica_yellow"
            android:textSize="30sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@color/slagalica_card"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/roundText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/round_one"
                android:textColor="@color/slagalica_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/currentPlayerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/current_player_one"
                android:textColor="@color/slagalica_text"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/timerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_30"
                android:textColor="@color/slagalica_text"
                android:textSize="17sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/playerOneScoreText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@color/slagalica_card"
                android:elevation="3dp"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/player_one_zero"
                android:textColor="@color/slagalica_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/playerTwoScoreText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@color/slagalica_card"
                android:elevation="3dp"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/player_two_zero"
                android:textColor="@color/slagalica_text"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/ruleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@color/slagalica_card"
            android:elevation="3dp"
            android:padding="14dp"
            android:text="@string/spojnice_rules"
            android:textColor="@color/slagalica_text"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/secondChanceInfoText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@color/slagalica_light_blue"
            android:elevation="3dp"
            android:padding="12dp"
            android:text="@string/second_chance_message"
            android:textColor="@color/slagalica_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <Button
                    android:id="@+id/left1Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="@string/adele"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/left2Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="@string/lady_gaga"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/left3Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="@string/ariana_grande"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/left4Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="@string/taylor_swift"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/left5Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="@string/beyonce"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <Button
                    android:id="@+id/right1Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="@string/halo"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/right2Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="@string/hello"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/right3Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="@string/shake_it_off"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/right4Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="@string/bad_romance"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/right5Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="@string/seven_rings"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/selectedPairText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@color/slagalica_card"
            android:elevation="3dp"
            android:padding="12dp"
            android:text="@string/selected_pair_none"
            android:textColor="@color/slagalica_text"
            android:textStyle="bold" />

        <Button
            android:id="@+id/confirmConnectionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/slagalica_yellow"
            android:text="@string/confirm_connection"
            android:textColor="@color/slagalica_dark_blue"
            android:textStyle="bold" />

        <Button
            android:id="@+id/spojniceQuitButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/slagalica_red"
            android:text="@string/quit_game"
            android:textColor="@color/white"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>