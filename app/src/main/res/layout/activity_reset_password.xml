<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/screen_padding">

        <TextView
            android:id="@+id/resetPasswordTitle"
            style="@style/SlagalicaTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_your_password"
            android:background="@color/slagalica_dark_blue"
            android:padding="@dimen/card_padding" />

        <LinearLayout
            style="@style/SlagalicaCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_large"
            android:orientation="vertical">

            <TextView
                android:id="@+id/resetDescriptionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reset_password_email_message"
                android:textColor="@color/slagalica_text"
                android:textSize="@dimen/body_text_size" />

            <EditText
                android:id="@+id/resetEmailInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_medium"
                android:hint="@string/email"
                android:inputType="textEmailAddress"
                android:textColor="@color/slagalica_text"
                android:textColorHint="@color/slagalica_text" />

            <LinearLayout
                android:id="@+id/changePasswordFieldsGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <EditText
                android:id="@+id/oldPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_medium"
                android:hint="@string/old_password"
                android:inputType="textPassword"
                android:textColor="@color/slagalica_text"
                android:textColorHint="@color/slagalica_text" />

            <EditText
                android:id="@+id/newPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_medium"
                android:hint="@string/new_password"
                android:inputType="textPassword"
                android:textColor="@color/slagalica_text"
                android:textColorHint="@color/slagalica_text" />

            <EditText
                android:id="@+id/repeatNewPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_medium"
                android:hint="@string/repeat_new_password"
                android:inputType="textPassword"
                android:textColor="@color/slagalica_text"
                android:textColorHint="@color/slagalica_text" />

            </LinearLayout>

            <TextView
                android:id="@+id/resetErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_small"
                android:textColor="@color/slagalica_red"
                android:textSize="@dimen/small_text_size"
                android:visibility="gone" />

            <Button
                android:id="@+id/confirmResetButton"
                style="@style/SlagalicaConfirmButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_large"
                android:text="@string/confirm" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
