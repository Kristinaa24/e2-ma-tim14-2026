<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="150dp"
    android:background="@drawable/bg_match_player_card"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="12dp">

    <FrameLayout
        android:layout_width="58dp"
        android:layout_height="58dp">

        <ImageView
            android:id="@+id/tournamentSlotAvatar"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/bg_match_avatar_frame"
            android:contentDescription="@string/player_avatar"
            android:padding="7dp"
            android:scaleType="center"
            android:src="@drawable/baseline_person_24" />
    </FrameLayout>

    <TextView
        android:id="@+id/tournamentSlotName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="Waiting"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tournamentSlotLeague"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="Empty slot"
        android:textColor="@color/slagalica_light_blue"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>