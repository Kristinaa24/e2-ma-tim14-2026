<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_round_title_bar"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:text="@string/my_number_title"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_round_board"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/roundOwnerText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/slagalica_light_blue"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/target_number_header"
                android:textColor="@color/slagalica_light_blue"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/targetNumberText"
                style="@style/SlagalicaQuestionField"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/target_number_placeholder"
                android:textSize="34sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/stopTargetButton"
                    style="@style/SlagalicaSecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="@string/stop_target_number" />

                <Button
                    android:id="@+id/stopNumbersButton"
                    style="@style/SlagalicaConfirmButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/stop_numbers" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_round_input_shell"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/offered_numbers_header"
                android:textColor="@color/slagalica_dark_blue"
                android:textSize="12sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="3">

                <Button
                    android:id="@+id/numberButton1"
                    style="@style/SlagalicaAnswerButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="@string/number_placeholder" />

                <Button
                    android:id="@+id/numberButton2"
                    style="@style/SlagalicaAnswerButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="@string/number_placeholder" />

                <Button
                    android:id="@+id/numberButton3"
                    style="@style/SlagalicaAnswerButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="@string/number_placeholder" />

                <Button
                    android:id="@+id/numberButton4"
                    style="@style/SlagalicaAnswerButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="@string/number_placeholder" />

                <Button
                    android:id="@+id/numberButton5"
                    style="@style/SlagalicaAnswerButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="@string/number_placeholder" />

                <Button
                    android:id="@+id/numberButton6"
                    style="@style/SlagalicaAnswerButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="@string/number_placeholder" />
            </GridLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_round_input_shell"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/operations_header"
                android:textColor="@color/slagalica_dark_blue"
                android:textSize="12sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="3">

                <Button
                    android:id="@+id/plusButton"
                    style="@style/SlagalicaSecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="+" />

                <Button
                    android:id="@+id/minusButton"
                    style="@style/SlagalicaSecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="-" />

                <Button
                    android:id="@+id/multiplyButton"
                    style="@style/SlagalicaSecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="*" />

                <Button
                    android:id="@+id/divideButton"
                    style="@style/SlagalicaSecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="/" />

                <Button
                    android:id="@+id/openBracketButton"
                    style="@style/SlagalicaSecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="(" />

                <Button
                    android:id="@+id/closeBracketButton"
                    style="@style/SlagalicaSecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text=")" />
            </GridLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_round_input_shell"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/activeInputText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/slagalica_dark_blue"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/my_number_player_one_expression_title"
                android:textColor="@color/slagalica_dark_blue"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/playerOneExpressionInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@android:color/transparent"
                android:hint="@string/enter_expression_hint"
                android:inputType="text"
                android:paddingBottom="8dp"
                android:textColor="@color/slagalica_text"
                android:textColorHint="@color/slagalica_text"
                android:textSize="@dimen/small_text_size" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/my_number_player_two_expression_title"
                android:textColor="@color/slagalica_dark_blue"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/playerTwoExpressionInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@android:color/transparent"
                android:hint="@string/enter_expression_hint"
                android:inputType="text"
                android:paddingBottom="8dp"
                android:textColor="@color/slagalica_text"
                android:textColorHint="@color/slagalica_text"
                android:textSize="@dimen/small_text_size" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/submitButton"
                    style="@style/SlagalicaConfirmButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="@string/my_number_preview_round" />

                <Button
                    android:id="@+id/clearButton"
                    style="@style/SlagalicaSecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/my_number_clear_active" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/resultText"
            style="@style/SlagalicaInfoCardBlue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:padding="12dp"
            android:text="@string/my_number_rules_extended"
            android:textSize="@dimen/small_text_size" />
    </LinearLayout>
</ScrollView>
