<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeActivity">

    <TextView
        android:id="@+id/homeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_title"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/userInfoText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/userInfoText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/user_info_placeholder"
        android:textSize="18sp"
        android:gravity="center"
        android:layout_margin="24dp"
        app:layout_constraintTop_toBottomOf="@id/homeTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/profileButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/profile"
        android:layout_margin="24dp"
        app:layout_constraintTop_toBottomOf="@id/userInfoText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/koZnaZnaButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/ko_zna_zna"
        android:layout_margin="24dp"
        app:layout_constraintTop_toBottomOf="@id/profileButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/spojniceButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/spojnice"
        android:layout_margin="24dp"
        app:layout_constraintTop_toBottomOf="@id/koZnaZnaButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/korakPoKorakButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/korak_po_korak"
        android:layout_margin="24dp"
        app:layout_constraintTop_toBottomOf="@id/spojniceButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/mojBrojButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/moj_broj"
        android:layout_margin="24dp"
        app:layout_constraintTop_toBottomOf="@id/korakPoKorakButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>