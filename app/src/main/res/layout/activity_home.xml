<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/slagalica_blue">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/homeToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/slagalica_light_blue"
            android:title="Slagalica"
            android:titleTextColor="@color/slagalica_yellow" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@drawable/bg_home_panel">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ready for a quiz battle?"
                        android:textColor="@color/slagalica_yellow"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Play as guest or sign in for rankings, rewards and profile stats."
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/startGameButton"
                        android:layout_width="match_parent"
                        android:layout_height="68dp"
                        android:layout_marginTop="22dp"
                        android:backgroundTint="@color/slagalica_yellow"
                        android:text="START GAME"
                        android:textColor="@color/slagalica_dark_blue"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="Players online: 37/74"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="76dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:gravity="center"
                        android:text="👤\nGuest"
                        android:textColor="@color/slagalica_dark_blue"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_home_card" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="76dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="6dp"
                        android:gravity="center"
                        android:text="⚡\nQuick play"
                        android:textColor="@color/slagalica_dark_blue"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_home_card" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="76dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:gravity="center"
                        android:text="🏆\nSign in to rank"
                        android:textColor="@color/slagalica_dark_blue"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_home_card" />

                </LinearLayout>



                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Available games"
                    android:textColor="@color/slagalica_yellow"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/koZnaZnaButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="🧠  Ko zna zna"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/spojniceButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="🔗  Spojnice"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/korakPoKorakButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="❓  Korak po korak"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/mojBrojButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/slagalica_card"
                    android:text="🔢  Moj broj"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textStyle="bold" />

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/slagalica_card"
        app:headerLayout="@layout/nav_header"
        app:itemIconTint="@color/slagalica_dark_blue"
        app:itemTextColor="@color/slagalica_dark_blue"
        app:itemTextAppearance="@style/NavItemText"
        app:menu="@menu/nav_menu" />

</androidx.drawerlayout.widget.DrawerLayout>