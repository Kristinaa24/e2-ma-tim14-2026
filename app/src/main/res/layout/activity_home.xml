<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_screen"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/homeToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name" />

        <include layout="@layout/player_status_bar" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/space_medium">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_home_panel"
                android:orientation="vertical"
                android:padding="@dimen/screen_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ready_for_battle"
                    android:textColor="@color/slagalica_yellow"
                    android:textSize="@dimen/subtitle_text_size"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/startGameButton"
                    style="@style/SlagalicaConfirmButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_medium"
                    android:text="@string/start_game"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_small"
                    android:gravity="center"
                    android:text="@string/players_online"
                    android:textColor="@color/white"
                    android:textSize="@dimen/small_text_size" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_medium"
                android:orientation="horizontal"
                android:weightSum="4">

                <TextView
                    android:id="@+id/tvProfile"
                    style="@style/SlagalicaCard"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:layout_margin="3dp"
                    android:gravity="center"
                    android:text="@string/profile_short"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvFriends"
                    style="@style/SlagalicaCard"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:layout_margin="3dp"
                    android:gravity="center"
                    android:text="@string/friends_short"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRanking"
                    style="@style/SlagalicaCard"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:layout_margin="3dp"
                    android:gravity="center"
                    android:text="@string/rank_short"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/notificationsMenuButton"
                    style="@style/SlagalicaCard"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:layout_margin="3dp"
                    android:gravity="center"
                    android:text="@string/alerts_short"
                    android:textColor="@color/slagalica_dark_blue"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_large"
                android:text="@string/available_games"
                android:textColor="@color/slagalica_yellow"
                android:textSize="@dimen/subtitle_text_size"
                android:textStyle="bold" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/space_small">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/koZnaZnaButton"
                        style="@style/SlagalicaAnswerButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="4dp"
                        android:text="🧠 Ko zna zna" />

                    <Button
                        android:id="@+id/spojniceButton"
                        style="@style/SlagalicaAnswerButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="4dp"
                        android:text="🔗 Spojnice" />

                    <Button
                        android:id="@+id/korakPoKorakButton"
                        style="@style/SlagalicaAnswerButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="4dp"
                        android:text="❓ Korak po korak" />

                    <Button
                        android:id="@+id/mojBrojButton"
                        style="@style/SlagalicaAnswerButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="4dp"
                        android:text="🔢 Moj broj" />

                    <Button
                        android:id="@+id/asocijacijeButton"
                        style="@style/SlagalicaAnswerButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="4dp"
                        android:text="🧩 Asocijacije" />

                    <Button
                        android:id="@+id/skockoButton"
                        style="@style/SlagalicaAnswerButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="4dp"
                        android:text="🧐 Skočko" />

                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/slagalica_card"
        android:orientation="vertical">

        <com.google.android.material.navigation.NavigationView
            android:id="@+id/navigationView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/slagalica_card"
            app:headerLayout="@layout/nav_header"
            app:itemIconTint="@color/slagalica_dark_blue"
            app:itemTextColor="@color/slagalica_dark_blue"
            app:menu="@menu/nav_menu" />

        <Button
            android:id="@+id/logoutButton"
            style="@style/SlagalicaDangerButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/screen_padding"
            android:text="@string/logout" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>