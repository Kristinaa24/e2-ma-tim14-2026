<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slagalica_dark_blue">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/moj_broj"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/roundText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/round_one_of_two"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/currentPlayerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/current_player_one_moj_broj"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/timerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/time_60"
            android:textColor="@color/slagalica_yellow"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/target_number_label"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/targetNumberText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/target_number_placeholder"
            android:textColor="@color/white"
            android:textSize="44sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/stopTargetButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stop_target_number"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/offered_numbers_label"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:layout_marginTop="12dp" />

        <GridLayout
            android:id="@+id/numbersGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/numberButton1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/number_placeholder" />

            <Button
                android:id="@+id/numberButton2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/number_placeholder" />

            <Button
                android:id="@+id/numberButton3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/number_placeholder" />

            <Button
                android:id="@+id/numberButton4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/number_placeholder" />

            <Button
                android:id="@+id/numberButton5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/number_placeholder" />

            <Button
                android:id="@+id/numberButton6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/number_placeholder" />
        </GridLayout>

        <Button
            android:id="@+id/stopNumbersButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stop_numbers"
            android:layout_marginTop="8dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/plusButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="+" />

            <Button
                android:id="@+id/minusButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="-" />

            <Button
                android:id="@+id/multiplyButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="*" />

            <Button
                android:id="@+id/divideButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="/" />

            <Button
                android:id="@+id/openBracketButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="(" />

            <Button
                android:id="@+id/closeBracketButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text=")" />
        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/expression_label"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/expressionInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/enter_expression_hint"
            android:textColor="@color/white"
            android:textColorHint="@color/light_gray"
            android:inputType="text" />

        <Button
            android:id="@+id/checkButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/check"
            android:layout_marginTop="6dp" />

        <Button
            android:id="@+id/clearButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/clear" />

        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/moj_broj_rules"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>