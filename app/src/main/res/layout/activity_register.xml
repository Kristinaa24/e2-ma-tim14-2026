<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/screen_padding">

        <TextView
            android:id="@+id/registerTitle"
            style="@style/SlagalicaTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/register"
            android:background="@color/slagalica_dark_blue"
            android:padding="@dimen/card_padding" />

        <LinearLayout
            style="@style/SlagalicaCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_large"
            android:orientation="vertical">

            <EditText
                android:id="@+id/usernameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/username"
                android:textColor="@color/slagalica_text"
                android:textColorHint="@color/slagalica_text" />

            <EditText
                android:id="@+id/emailInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_medium"
                android:hint="@string/email"
                android:inputType="textEmailAddress"
                android:textColor="@color/slagalica_text"
                android:textColorHint="@color/slagalica_text" />

            <AutoCompleteTextView
                android:id="@+id/regionInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_medium"
                android:hint="@string/select_region"
                android:inputType="none"
                android:focusable="true"
                android:textColor="@color/slagalica_text"
                android:textColorHint="@color/slagalica_text" />

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_medium"
                android:hint="@string/password"
                android:inputType="textPassword"
                android:textColor="@color/slagalica_text"
                android:textColorHint="@color/slagalica_text" />

            <EditText
                android:id="@+id/repeatPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_medium"
                android:hint="@string/repeat_password"
                android:inputType="textPassword"
                android:textColor="@color/slagalica_text"
                android:textColorHint="@color/slagalica_text" />

            <TextView
                android:id="@+id/registerErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_small"
                android:textColor="@color/slagalica_red"
                android:textSize="@dimen/small_text_size"
                android:visibility="gone" />

            <Button
                android:id="@+id/registerButton"
                style="@style/SlagalicaConfirmButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_large"
                android:text="@string/register" />

            <TextView
                android:id="@+id/backToLoginText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_medium"
                android:gravity="center"
                android:text="@string/back_to_login"
                android:textColor="@color/slagalica_dark_blue"
                android:textSize="@dimen/body_text_size"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
