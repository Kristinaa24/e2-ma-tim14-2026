<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slagalica_blue"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Header -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/notifToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/slagalica_light_blue"
        app:title="@string/notifications"
        app:titleTextColor="@color/slagalica_dark_blue" />

    <!-- Filters Bar (Requirement 11.d) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnAllNotifs"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="@color/slagalica_yellow"
            android:text="@string/all_notifications"
            android:textColor="@color/slagalica_dark_blue"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnReadNotifs"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:backgroundTint="@color/slagalica_light_blue"
            android:text="@string/read_notifications"
            android:textColor="@color/slagalica_dark_blue"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnUnreadNotifs"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:backgroundTint="@color/slagalica_light_blue"
            android:text="@string/unread_notifications"
            android:textColor="@color/slagalica_dark_blue"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">
            <include layout="@layout/item_notification" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
            <include layout="@layout/item_notification" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
            <include layout="@layout/item_notification" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnBackFromNotif"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:backgroundTint="@color/slagalica_yellow"
        android:text="@string/back_to_home"
        android:textColor="@color/slagalica_dark_blue"
        android:textStyle="bold" />

</LinearLayout>