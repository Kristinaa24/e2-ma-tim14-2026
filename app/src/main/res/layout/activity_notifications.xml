<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slagalica_blue"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Header -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/notifToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/slagalica_light_blue"
        app:title="Notifikacije"
        app:titleTextColor="@color/slagalica_dark_blue" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">
            <include layout="@layout/item_notification" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
            <include layout="@layout/item_notification" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
            <include layout="@layout/item_notification" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnBackFromNotif"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:backgroundTint="@color/slagalica_yellow"
        android:text="Nazad na početnu"
        android:textColor="@color/slagalica_dark_blue"
        android:textStyle="bold" />

</LinearLayout>