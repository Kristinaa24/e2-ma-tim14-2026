<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/resultTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_round_title_bar"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:text="@string/match_finished_title"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_round_board"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/resultSummaryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/match_result_summary"
                android:textColor="@color/slagalica_light_blue"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/resultPlayerOneScoreText"
                style="@style/SlagalicaQuestionField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:padding="14dp"
                android:text="@string/match_result_player_one_format" />

            <TextView
                android:id="@+id/resultPlayerTwoScoreText"
                style="@style/SlagalicaQuestionField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:padding="14dp"
                android:text="@string/match_result_player_two_format" />

            <TextView
                android:id="@+id/resultWinnerText"
                style="@style/SlagalicaInfoCardBlue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:padding="14dp"
                android:text="@string/match_result_draw" />
        </LinearLayout>

        <Button
            android:id="@+id/resultBackButton"
            style="@style/SlagalicaSecondaryButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:text="@string/back_to_main_room" />

        <Button
            android:id="@+id/resultRematchButton"
            style="@style/SlagalicaConfirmButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="@string/play_rematch" />
    </LinearLayout>
</ScrollView>
