<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <include layout="@layout/player_status_bar" />

        <TextView
            android:id="@+id/kpkTitle"
            style="@style/SlagalicaTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@color/slagalica_dark_blue"
            android:padding="10dp"
            android:text="@string/korak_po_korak" />

        <LinearLayout
            style="@style/SlagalicaCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/timerText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/time_70"
                android:textColor="@color/slagalica_text"
                android:textSize="@dimen/body_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/scoreText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:text="@string/score_0"
                android:textColor="@color/slagalica_text"
                android:textSize="@dimen/small_text_size"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/step1Text"
            style="@style/SlagalicaQuestionField"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="@string/step_1_sunce" />

        <TextView
            android:id="@+id/step2Text"
            style="@style/SlagalicaQuestionField"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="" />

        <TextView
            android:id="@+id/step3Text"
            style="@style/SlagalicaQuestionField"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="" />

        <TextView
            android:id="@+id/step4Text"
            style="@style/SlagalicaQuestionField"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="" />

        <TextView
            android:id="@+id/step5Text"
            style="@style/SlagalicaQuestionField"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="" />

        <TextView
            android:id="@+id/step6Text"
            style="@style/SlagalicaQuestionField"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="" />

        <TextView
            android:id="@+id/step7Text"
            style="@style/SlagalicaQuestionField"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="" />

        <LinearLayout
            style="@style/SlagalicaCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical"
            android:padding="10dp">

            <EditText
                android:id="@+id/answerInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enter_final_answer"
                android:textColor="@color/slagalica_text"
                android:textColorHint="@color/slagalica_text" />

            <Button
                android:id="@+id/nextStepButton"
                style="@style/SlagalicaSecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:text="@string/next_step" />

            <Button
                android:id="@+id/submitButton"
                style="@style/SlagalicaConfirmButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:text="@string/submit_answer" />
        </LinearLayout>

        <Button
            android:id="@+id/quitGameButton"
            style="@style/SlagalicaDangerButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:text="@string/quit_game" />

    </LinearLayout>

</ScrollView>