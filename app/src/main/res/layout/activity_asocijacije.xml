<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slagalica_blue"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Status Bar: Tokens, Stars, League (Persistent during game) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/slagalica_dark_blue"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/tokenStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🪙 5"
            android:textColor="@color/slagalica_yellow"
            android:textSize="12sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/starStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⭐ 120"
            android:textColor="@color/slagalica_yellow"
            android:textSize="12sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/leagueStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🥈 Silver"
            android:textColor="@color/slagalica_yellow"
            android:textSize="12sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Header: Scores and Timer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp">

        <TextView
            android:id="@+id/player1Score"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="P1: 0"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/timerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/avatar_silver"
            android:padding="8dp"
            android:text="120s"
            android:textColor="@color/slagalica_dark_blue"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/player2Score"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="P2: 0"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/asocijacije"
        android:textColor="@color/slagalica_yellow"
        android:textSize="24sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Columns A and B -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Column A -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <Button android:id="@+id/btnA1" android:layout_width="match_parent" android:layout_height="45dp" android:text="A1" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <Button android:id="@+id/btnA2" android:layout_width="match_parent" android:layout_height="45dp" android:text="A2" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <Button android:id="@+id/btnA3" android:layout_width="match_parent" android:layout_height="45dp" android:text="A3" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <Button android:id="@+id/btnA4" android:layout_width="match_parent" android:layout_height="45dp" android:text="A4" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <EditText android:id="@+id/etSolutionA" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/column_a" android:gravity="center" android:background="@color/slagalica_yellow" android:padding="8dp" android:textColor="@color/slagalica_dark_blue" android:textSize="14sp"/>
                </LinearLayout>

                <!-- Column B -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <Button android:id="@+id/btnB1" android:layout_width="match_parent" android:layout_height="45dp" android:text="B1" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <Button android:id="@+id/btnB2" android:layout_width="match_parent" android:layout_height="45dp" android:text="B2" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <Button android:id="@+id/btnB3" android:layout_width="match_parent" android:layout_height="45dp" android:text="B3" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <Button android:id="@+id/btnB4" android:layout_width="match_parent" android:layout_height="45dp" android:text="B4" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <EditText android:id="@+id/etSolutionB" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/column_b" android:gravity="center" android:background="@color/slagalica_yellow" android:padding="8dp" android:textColor="@color/slagalica_dark_blue" android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Final Solution Field -->
            <EditText
                android:id="@+id/etFinalSolution"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:background="@color/slagalica_red"
                android:gravity="center"
                android:hint="@string/final_solution"
                android:padding="12dp"
                android:textColor="@color/white"
                android:textColorHint="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Columns C and D -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Column C -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <EditText android:id="@+id/etSolutionC" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/column_c" android:gravity="center" android:background="@color/slagalica_yellow" android:padding="8dp" android:textColor="@color/slagalica_dark_blue" android:textSize="14sp"/>
                    <Button android:id="@+id/btnC1" android:layout_width="match_parent" android:layout_height="45dp" android:text="C1" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <Button android:id="@+id/btnC2" android:layout_width="match_parent" android:layout_height="45dp" android:text="C2" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <Button android:id="@+id/btnC3" android:layout_width="match_parent" android:layout_height="45dp" android:text="C3" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <Button android:id="@+id/btnC4" android:layout_width="match_parent" android:layout_height="45dp" android:text="C4" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                </LinearLayout>

                <!-- Column D -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <EditText android:id="@+id/etSolutionD" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/column_d" android:gravity="center" android:background="@color/slagalica_yellow" android:padding="8dp" android:textColor="@color/slagalica_dark_blue" android:textSize="14sp"/>
                    <Button android:id="@+id/btnD1" android:layout_width="match_parent" android:layout_height="45dp" android:text="D1" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <Button android:id="@+id/btnD2" android:layout_width="match_parent" android:layout_height="45dp" android:text="D2" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <Button android:id="@+id/btnD3" android:layout_width="match_parent" android:layout_height="45dp" android:text="D3" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                    <Button android:id="@+id/btnD4" android:layout_width="match_parent" android:layout_height="45dp" android:text="D4" android:backgroundTint="@color/slagalica_light_blue" android:textColor="@color/slagalica_dark_blue"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/confirmSolutionButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/slagalica_yellow"
        android:text="POTVRDI"
        android:textColor="@color/slagalica_dark_blue"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnQuitAsocijacije"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/slagalica_red"
        android:text="Napusti igru"
        android:textColor="@color/white"
        android:textStyle="bold" />

</LinearLayout>