<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="56dp"
        android:background="@drawable/bg_chat_message_received"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/chatSenderNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chat_player_fallback"
            android:textColor="@color/slagalica_dark_blue"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/chatMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/slagalica_dark_blue"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/chatSentAtText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#4B5D8A"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
