<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="NavItemText">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SlagalicaTitle">
        <item name="android:textColor">@color/slagalica_yellow</item>
        <item name="android:textSize">@dimen/title_text_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="SlagalicaCard">
        <item name="android:background">@color/slagalica_card</item>
        <item name="android:padding">@dimen/card_padding</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="SlagalicaInfoCardBlue">
        <item name="android:background">@color/slagalica_light_blue</item>
        <item name="android:textColor">@color/slagalica_text</item>
        <item name="android:padding">@dimen/card_padding</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="SlagalicaQuestionField">
        <item name="android:background">@color/slagalica_yellow</item>
        <item name="android:textColor">@color/slagalica_dark_blue</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">@dimen/card_padding</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="SlagalicaAnswerButton">
        <item name="android:backgroundTint">@color/slagalica_card</item>
        <item name="android:textColor">@color/slagalica_dark_blue</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <style name="SlagalicaSecondaryButton">
        <item name="android:backgroundTint">@color/slagalica_light_blue</item>
        <item name="android:textColor">@color/slagalica_dark_blue</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <style name="SlagalicaConfirmButton">
        <item name="android:backgroundTint">@color/slagalica_yellow</item>
        <item name="android:textColor">@color/slagalica_dark_blue</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <style name="SlagalicaDangerButton">
        <item name="android:backgroundTint">@color/slagalica_red</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <style name="Widget.Slagalica.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/slagalica_light_blue</item>
        <item name="titleTextColor">@color/slagalica_dark_blue</item>
    </style>

    <style name="Widget.Slagalica.Button" parent="Widget.Material3.Button">
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">16dp</item>
    </style>

</resources>